{
  "name": "onnx-asr-web",
  "version": "0.1.2",
  "description": "JavaScript ONNX ASR for Node.js and browser",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./node": "./dist/node.js",
    "./browser": "./dist/browser.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "node --check src/*.js examples/node/transcribe.mjs examples/browser/main.js examples/browser-cdn/main.js scripts/build.mjs",
    "prepublishOnly": "npm run build && npm run check"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "keywords": [
    "onnx",
    "asr",
    "onnxruntime-web",
    "speech-to-text"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SanderGi/onnx-asr-web.git"
  },
  "homepage": "https://github.com/SanderGi/onnx-asr-web#readme",
  "bugs": {
    "url": "https://github.com/SanderGi/onnx-asr-web/issues"
  },
  "dependencies": {
    "onnxruntime-web": "^1.24.2"
  },
  "devDependencies": {
    "esbuild": "^0.27.3"
  }
}
